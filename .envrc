# direnv auto-configuration
# Run: direnv allow .
# Then: cd into the project and everything loads automatically

export PROJECT_ROOT=$(pwd)
export PYTHONPATH="$PROJECT_ROOT:$PYTHONPATH"

# Activate virtualenv
if [ -d "$PROJECT_ROOT/venv" ]; then
    source "$PROJECT_ROOT/venv/bin/activate"
fi

# Auto-decrypt secrets (requires SOPS + Age key configured)
if [ -f "$PROJECT_ROOT/.env.enc" ]; then
    if sops -d "$PROJECT_ROOT/.env.enc" > "$PROJECT_ROOT/.env" 2>/dev/null; then
        set -a
        source "$PROJECT_ROOT/.env"
        set +a
    fi
fi

# Defaults for local development
export REDIS_URL="${REDIS_URL:-redis://localhost:6379/0}"
export OTLP_ENDPOINT="${OTLP_ENDPOINT:-http://localhost:4317}"
export WORKSPACE_ROOT="${WORKSPACE_ROOT:-$PROJECT_ROOT}"
export REPORTS_DIR="${REPORTS_DIR:-$PROJECT_ROOT/reports/output}"
export ENVIRONMENT="${ENVIRONMENT:-development}"
export ENGINE_VERSION="2.0.0"

echo "✅ ide-agentic-engine environment loaded"
echo "   Python: $(python3 --version 2>/dev/null || echo 'not in venv')"
echo "   Redis:  $REDIS_URL"
