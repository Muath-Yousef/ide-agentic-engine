# LLM
GEMINI_API_KEY=your_gemini_key_here
GEMINI_RPM_LIMIT=15

# SOAR Safety
SOAR_DRY_RUN=true

# Cloudflare (WAF/CDN)
CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=your_cloudflare_zone_id

# Telegram Setup
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID_FINDINGS=your_findings_channel_id
TELEGRAM_CHAT_ID_ACTIONS=your_actions_channel_id
TELEGRAM_CHAT_ID_FAILURES=your_failures_channel_id

# VirusTotal
VT_API_KEY=your_virustotal_key_here

# Email Notification System
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=security@yourdomain.com

# Custom NVD Optional Key (if rate limited by NVD)
# NVD_API_KEY=optional_key_here
